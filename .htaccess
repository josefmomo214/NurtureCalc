# Next.js Static Export .htaccess Configuration for Hostinger
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect www to non-www
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]


  # 1. Ensure assets in _next/ are served directly without redirection
  # This fixes the "no styling" issue by ensuring CSS/JS are loaded correctly
  RewriteCond %{REQUEST_URI} ^/_next/ [NC]
  RewriteRule ^ - [L]

  # 2. Force trailing slashes for routes (matches Next.js trailingSlash: true)
  # Redirects /blog/guide to /blog/guide/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(.*)\.html$
  RewriteCond %{REQUEST_URI} !(.*)\.(js|css|png|jpg|jpeg|gif|ico|svg|json|webp)$
  RewriteRule ^(.*[^/])$ /$1/ [L,R=301]

  # 3. Serve the index.html file from within the route folder
  # Maps /blog/guide/ to /blog/guide/index.html
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)/$ $1/index.html [L]

  # 4. Fallback for clean URLs if the direct folder doesn't match
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.*)/?$ $1/index.html [L]

  # 5. Handle standard .html extensions if accessed directly (optional cleanup)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # 6. Custom 404 Page mapping
  ErrorDocument 404 /404.html
</IfModule>
