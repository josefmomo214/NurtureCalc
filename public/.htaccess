Options -MultiViews
RewriteEngine On

# SEO 301 redirects
RewriteRule ^calorie-needs/?$ /breastfeeding-calories/ [R=301,L]
RewriteRule ^baby-weight/?$ /baby-weight-percentile/ [R=301,L]

# Serve existing static files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# For clean URLs, look for index.html in the subdirectory
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)$ $1/index.html [L]

# Fallback to 404
RewriteRule ^ /404.html [L]
